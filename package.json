{
  "name": "@bch2/swap-core",
  "version": "3.1.8",
  "description": "Non-custodial BCH2 <-> EVM atomic-swap SDK: HTLC crypto, swap state engine, and order-book client for building bots on the BCH2 Swap DEX.",
  "type": "module",
  "license": "MIT",
  "author": "BCH2",
  "homepage": "https://swap.bch2.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BitcoincashII/bch2-swap-core.git"
  },
  "keywords": [
    "bch2",
    "atomic-swap",
    "htlc",
    "dex",
    "cross-chain",
    "cashtokens",
    "evm",
    "trading-bot"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./order-book": {
      "types": "./dist/order-book/index.d.ts",
      "import": "./dist/order-book/index.js"
    },
    "./htlc-builder": {
      "types": "./dist/htlc-builder.d.ts",
      "import": "./dist/htlc-builder.js"
    },
    "./spv": {
      "types": "./dist/spv.d.ts",
      "import": "./dist/spv.js"
    },
    "./spv-verifier": {
      "types": "./dist/spv-verifier.d.ts",
      "import": "./dist/spv-verifier.js"
    },
    "./chain-client": {
      "types": "./dist/chain-client.d.ts",
      "import": "./dist/chain-client.js"
    },
    "./seed-secret": {
      "types": "./dist/seed-secret.d.ts",
      "import": "./dist/seed-secret.js"
    },
    "./chain-config": {
      "types": "./dist/chain-config.d.ts",
      "import": "./dist/chain-config.js"
    },
    "./timelock-gates": {
      "types": "./dist/timelock-gates.d.ts",
      "import": "./dist/timelock-gates.js"
    },
    "./gates": {
      "types": "./dist/gates.d.ts",
      "import": "./dist/gates.js"
    },
    "./utxo-reservation": {
      "types": "./dist/utxo-reservation.d.ts",
      "import": "./dist/utxo-reservation.js"
    },
    "./storage": {
      "types": "./dist/storage.d.ts",
      "import": "./dist/storage.js"
    },
    "./swap-controller": {
      "types": "./dist/swap-controller.d.ts",
      "import": "./dist/swap-controller.js"
    },
    "./fee-rate": {
      "types": "./dist/fee-rate.d.ts",
      "import": "./dist/fee-rate.js"
    },
    "./swap-flow": {
      "types": "./dist/swap-flow.d.ts",
      "import": "./dist/swap-flow.js"
    },
    "./address-codec": {
      "types": "./dist/address-codec.d.ts",
      "import": "./dist/address-codec.js"
    },
    "./key-encryption": {
      "types": "./dist/key-encryption.d.ts",
      "import": "./dist/key-encryption.js"
    },
    "./wallet-core": {
      "types": "./dist/wallet-core.d.ts",
      "import": "./dist/wallet-core.js"
    },
    "./evm": {
      "types": "./dist/evm/contracts.d.ts",
      "import": "./dist/evm/contracts.js"
    },
    "./evm-config": {
      "types": "./dist/evm-config.d.ts",
      "import": "./dist/evm-config.js"
    },
    "./evm-client": {
      "types": "./dist/evm-client.d.ts",
      "import": "./dist/evm-client.js"
    },
    "./evm-native-send": {
      "types": "./dist/evm-native-send.d.ts",
      "import": "./dist/evm-native-send.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "verify:live": "node scripts/verify-live-spv.mjs"
  },
  "dependencies": {
    "@noble/ciphers": "2.2.0",
    "@noble/curves": "1.9.7",
    "@noble/hashes": "1.8.0",
    "@noble/secp256k1": "2.3.0",
    "@scure/bip32": "1.7.0",
    "@scure/bip39": "1.6.0",
    "buffer": "^6.0.3",
    "ethers": "^6.16.0",
    "viem": "2.52.2"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.3.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  }
}
